# xAI API key — get one at console.x.ai
# Enable the data-sharing program for $175/mo in free credits
XAI_API_KEY=xai-...

# Optional: override TV IP if SSDP discovery fails
# FRAMEFORGE_TV_HOST=192.168.1.100

# Optional: where to store images (default: ~/Pictures/FrameForge)
# FRAMEFORGE_LIBRARY=/path/to/library

# Optional: server binding (defaults: 127.0.0.1:8765).
# Set BIND_HOST=0.0.0.0 to reach the web UI from a phone on your network —
# and set an API token when you do.
# FRAMEFORGE_BIND_HOST=0.0.0.0
# FRAMEFORGE_BIND_PORT=8765

# Optional: require this token on every API request (Bearer header or ?token=).
# Open the UI once as http://<mac-ip>:8765/?token=<value>; the browser stores it.
# FRAMEFORGE_API_TOKEN=change-me
